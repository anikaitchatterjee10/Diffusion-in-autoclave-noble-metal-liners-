override_w = pn.widgets.Checkbox(name="Override Surface Conc.", value=False)
custom_c0_w = pn.widgets.FloatInput(name="Custom Conc. (cm⁻³)", value=1e20, disabled=True)

override_w.link(custom_c0_w, callbacks={'value': lambda target, event: setattr(target, 'disabled', not event.new)})

# 3. Plots Setup
def create_fig(title, y_log=False, x_label="Depth (cm)"):
    return figure(width=850, height=400, title=title, 
                  y_axis_type="log" if y_log else "linear", 
                  x_axis_label=x_label, y_axis_label="Conc (cm^-3)")

fig_d_lin = create_fig("Depth Profile (Linear)")
fig_d_log = create_fig("Depth Profile (Log)", y_log=True)
fig_t_lin = create_fig("Time Profile (Linear)", x_label="Time (days)")
fig_t_log = create_fig("Time Profile (Log)", y_log=True, x_label="Time (days)")

sources_depth_line = {el: ColumnDataSource(data=dict(xs=[], ys=[])) for el in ELEMENTS}
sources_depth_patch = {el: ColumnDataSource(data=dict(xp=[], yp=[])) for el in ELEMENTS}
sources_time_line = {el: ColumnDataSource(data=dict(xs=[], ys=[])) for el in ELEMENTS}
sources_time_patch = {el: ColumnDataSource(data=dict(xp=[], yp=[])) for el in ELEMENTS}

colors = Category10[10] * 2
for i, el in enumerate(ELEMENTS):
    c = colors[i]
    for f in [fig_d_lin, fig_d_log]:
        f.patch('xp', 'yp', source=sources_depth_patch[el], color=c, alpha=0.2, legend_label=el, line_alpha=0)
        f.multi_line('xs', 'ys', source=sources_depth_line[el], color=c, line_width=2)
    for f in [fig_t_lin, fig_t_log]:
        f.patch('xp', 'yp', source=sources_time_patch[el], color=c, alpha=0.2, legend_label=el, line_alpha=0)
        f.multi_line('xs', 'ys', source=sources_time_line[el], color=c, line_width=2)

for f in [fig_d_lin, fig_d_log, fig_t_lin, fig_t_log]:
    f.legend.click_policy = "hide"
    f.legend.label_text_font_size = "8pt"

@pn.depends(alloy_w, group_w, temp_w, time_w, thick_w, override_w, custom_c0_w, watch=True)
def update_logic(alloy, group, temp, days, thick, override, custom_c0):
    t_sec_now = days * 86400
    t_sec_grid = T_GRID_DAYS * 86400
    T_k = temp + 273.15
    allowed = PERIODIC_GROUPS[group]
    comp = alloys[alloy]['comp']
    dens = alloys[alloy]['dens']
    
    for el in ELEMENTS:
        c_wt = comp.get(el, 0)
        if el not in allowed or c_wt == 0:
            sources_depth_line[el].data = dict(xs=[], ys=[])
            sources_depth_patch[el].data = dict(xp=[], yp=[])
            sources_time_line[el].data = dict(xs=[], ys=[])
            sources_time_patch[el].data = dict(xp=[], yp=[])
            continue
            
        if override:
            c0 = custom_c0
        else:
            c0 = (dens * (c_wt/100) * 6.022e23) / atom_database[el]
            
        ds = [p[0] * np.exp(-p[1] / (R * T_k)) for p in alloy_imp_dict[el]]
        d_p = [c0 * (1 - erf(X_GRID / (2 * np.sqrt(d * t_sec_now)))) for d in ds]
        y_min_d, y_max_d = np.min(d_p, axis=0), np.max(d_p, axis=0)
        sources_depth_line[el].data = dict(xs=[X_GRID] * len(d_p), ys=d_p)
        sources_depth_patch[el].data = dict(xp=np.concatenate([X_GRID, X_GRID[::-1]]), 
                                              yp=np.concatenate([y_min_d, y_max_d[::-1]]))
        
        t_p = [c0 * (1 - erf(thick / (2 * np.sqrt(d * t_sec_grid)))) for d in ds]
        y_min_t, y_max_t = np.min(t_p, axis=0), np.max(t_p, axis=0)
        sources_time_line[el].data = dict(xs=[T_GRID_DAYS] * len(t_p), ys=t_p)
        sources_time_patch[el].data = dict(xp=np.concatenate([T_GRID_DAYS, T_GRID_DAYS[::-1]]),
                                             yp=np.concatenate([y_min_t, y_max_t[::-1]]))

    for f in [fig_d_lin, fig_d_log]: f.x_range.end = thick
    for f in [fig_t_lin, fig_t_log]: f.x_range.end = days

update_logic(alloy_w.value, group_w.value, temp_w.value, time_w.value, thick_w.value, override_w.value, custom_c0_w.value)

tabs = pn.Tabs(("Depth (Lin)", fig_d_lin), ("Depth (Log)", fig_d_log), ("Time (Lin)", fig_t_lin), ("Time (Log)", fig_t_log))

pn.Column(
    pn.Row(alloy_w, group_w, temp_w, time_w, thick_w), 
    pn.Row(override_w, custom_c0_w),
    tabs
).servable()
