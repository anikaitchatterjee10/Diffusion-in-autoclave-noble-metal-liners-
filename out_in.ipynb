atom_database = {
    "Ni": 58.69, "Fe": 55.85, "Cr": 52.00, "Nb": 92.91, "Mo": 95.95, "Co": 58.93,
    "Ti": 47.87, "Al": 26.98, "Mn": 54.94, "Si": 28.09, "Cu": 63.55, "C": 12.01,
    "Ta": 180.95, "P": 30.97, "S": 32.07, "B": 10.81, "W": 183.84, "Zr": 91.22
}

R = 8.31446e-3 
ELEMENTS = list(alloy_imp_dict.keys())
X_GRID = np.linspace(0, 0.5, 500)
T_GRID_DAYS = np.linspace(0.1, 1000, 500)

# 2. UI Widgets
alloy_w = pn.widgets.Select(name="Alloy", options=list(alloys.keys()))
group_w = pn.widgets.Select(name="Periodic Group Filter", options=list(PERIODIC_GROUPS.keys()))
